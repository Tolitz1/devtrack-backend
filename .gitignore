# ------------------------------
# Python
# ------------------------------
__pycache__/      
# Folder where Python stores compiled bytecode cache files (auto-generated, not needed)
*.py[cod]         
# Ignore .pyc .pyo .pyd files — compiled versions of your .py files (auto-generated)
*$py.class        
# Java-style compiled Python class files (rare, but auto-generated)
*.so              
# Compiled C extension files (binary, platform-specific, auto-generated)
.Python           
# Symlink created by some Python installations (not needed in repo)

# Virtual environments
venv/             
# Most common virtual environment folder name
env/              
# Another common virtual environment folder name
ENV/              
# Uppercase variant of env/ (same purpose)
.venv/            
# Hidden virtual environment folder (starts with dot)
# ^ All 4 above: contain installed packages — huge folders, recreatable via pip install

# ------------------------------
# Environment Variables
# ------------------------------
.env              
# The main secrets file (passwords, API keys) — NEVER commit this
.env.*            
# Any variant like .env.production .env.local .env.staging — all ignored
!.env.example     
# EXCEPTION: this one IS committed — it's a safe template with placeholder values

# ------------------------------
# Database
# ------------------------------
*.db              
# Any SQLite or generic database file (contains your local data, not for sharing)
*.sqlite3         
# SQLite3 database files specifically (same reason as above)

# ------------------------------
# Logs
# ------------------------------
*.log             
# Any log file — auto-generated, can be huge, contains runtime info not needed in repo

# ------------------------------
# Testing / Coverage
# ------------------------------
.coverage         
# File generated by pytest-cov showing which lines were tested
htmlcov/          
# Folder with HTML report of test coverage (generated by coverage.py)
.pytest_cache/    
# Pytest's internal cache folder (stores test results to speed up reruns)

# ------------------------------
# Build / Distribution
# ------------------------------
build/            
# Output folder when building your Python package
dist/             
# Folder containing final distributable files (.whl, .tar.gz) for PyPI upload
*.egg-info/       
# Metadata folder generated when installing a package in editable mode (pip install -e .)

# ------------------------------
# IDE
# ------------------------------
.vscode/          
# VS Code editor settings folder (personal preferences, not project code)
.idea/            
# PyCharm/IntelliJ editor settings folder (same reason)
*.swp             
# Vim temporary swap file (created while editing, deleted when Vim closes normally)
*.swo             
# Vim secondary swap file (created if .swp already exists)

# ------------------------------
# macOS / Windows
# ------------------------------
.DS_Store         
# macOS auto-generated file storing folder display preferences (useless to others)
Thumbs.db         
# Windows auto-generated file storing folder thumbnail cache (useless to others)